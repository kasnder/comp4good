---
import Base from '../layouts/Base.astro';
import { content, projectLabels } from '../data/content';
import publications from '../data/publications.json';

type Pub = {
  year: number;
  title: string;
  authors: string;
  venue: string;
  type: 'conference' | 'journal' | 'preprint' | 'book';
  url?: string;
  projects?: string[];
  highlight?: boolean;
  highlightRank?: number;
};

// Every lab-member paper from the shared feed (year >= 2024). A couple of
// highlighted, recent papers show open at the top; the rest are tucked into
// per-year collapsibles below — same pattern as kollnig.net's press page.
const pubs = publications as Pub[];
const highlights = pubs
  .filter((p) => p.highlight)
  .sort((a, b) => (a.highlightRank ?? 999) - (b.highlightRank ?? 999) || b.year - a.year);
const archive = pubs.filter((p) => !p.highlight);
const archiveYears = [...new Set(archive.map((p) => p.year))].sort((a, b) => b - a);
const typeLabel: Record<Pub['type'], string> = {
  conference: 'Conference',
  journal: 'Journal',
  preprint: 'Preprint',
  book: 'Book',
};
const projectMeta: Record<string, { label: string; url: string }> = Object.fromEntries(
  content.projects.map((project) => [
    project.id,
    { label: projectLabels[project.id] ?? project.title, url: project.link },
  ]),
);
---
<Base path="/">
  <div class="wrap home">
    <p class="thesis">
      {content.mission.thesis.map((line, i) => (
        <>
          {i === content.mission.thesis.length - 1 ? <em>{line}</em> : line}
          {i < content.mission.thesis.length - 1 && <br />}
        </>
      ))}
    </p>
    <p class="mission-desc">{content.mission.description}</p>

    <h2 class="section-label" id="themes">Research Themes</h2>
    {content.themes.map((theme) => (
      <div class="question">
        <p class="q-eyebrow">{theme.eyebrow}</p>
        <h3>{theme.question}</h3>
        <p>{theme.body}</p>
        <p class="refs">{theme.refs}</p>
      </div>
    ))}

    <h2 class="section-label" id="projects">Projects</h2>
    <div class="projects">
      {content.projects.map((project) => (
        <a class="project-card" href={project.link} target="_blank" rel="noopener">
          <img class="project-logo" src={project.logo} alt="" loading="lazy" />
          <div class="project-body">
            <h3>{project.title}</h3>
            <p class="project-subtitle">{project.subtitle}</p>
            <p class="project-desc">{project.description}</p>
            <p class="project-funder">{project.funder}</p>
          </div>
        </a>
      ))}
    </div>

    <h2 class="section-label" id="team">Team</h2>
    <div class="team-grid">
      {content.team.map((member) => (
        <div class="team-member">
          <img src={member.image} alt={member.name} loading="lazy" />
          <p class="team-name">{member.name}</p>
          <p class="team-role">{member.role}</p>
          <p class="team-projects">
            {member.projects.map((p) => <span class="tag">{projectLabels[p]}</span>)}
          </p>
        </div>
      ))}
    </div>
    <div class="collaborators">
      <p class="collab-label">Collaborators</p>
      <p class="collab-list">{content.partners.join(' · ')}</p>
    </div>

    <h2 class="section-label" id="publications">Publications</h2>
    <p class="pub-intro">Recent work from across our group — a few highlights below,
      with the full list by year underneath. For each member's complete record, see
      the individual project sites above.</p>

    <ol class="pub-list highlights">
      {highlights.map((p) => (
        <li class="pub">
          <h3 class="pub-title">
            {p.url ? <a href={p.url} target="_blank" rel="noopener">{p.title}</a> : p.title}
          </h3>
          <p class="pub-authors">{p.authors}</p>
          <p class="pub-venue">
            <span class="venue">{p.venue}</span>
            <span class="year">{p.year}</span>
            <span class="tag">{typeLabel[p.type]}</span>
            {p.projects?.map((pr) => projectMeta[pr] && (
              <a class="tag project-tag" href={projectMeta[pr].url} target="_blank" rel="noopener"
                title={`${projectMeta[pr].label} project`}>{projectMeta[pr].label}</a>
            ))}
          </p>
        </li>
      ))}
    </ol>

    {archiveYears.map((year) => (
      <details class="archive-section">
        <summary>
          <span class="summary-title">{year}</span>
          <span class="summary-count">{archive.filter((p) => p.year === year).length} {archive.filter((p) => p.year === year).length === 1 ? 'paper' : 'papers'}</span>
        </summary>
        <ol class="pub-list">
          {archive.filter((p) => p.year === year).map((p) => (
            <li class="pub">
              <h3 class="pub-title">
                {p.url ? <a href={p.url} target="_blank" rel="noopener">{p.title}</a> : p.title}
              </h3>
              <p class="pub-authors">{p.authors}</p>
              <p class="pub-venue">
                <span class="venue">{p.venue}</span>
                <span class="tag">{typeLabel[p.type]}</span>
                {p.projects?.map((pr) => projectMeta[pr] && (
                  <a class="tag project-tag" href={projectMeta[pr].url} target="_blank" rel="noopener"
                    title={`${projectMeta[pr].label} project`}>{projectMeta[pr].label}</a>
                ))}
              </p>
            </li>
          ))}
        </ol>
      </details>
    ))}

    <h2 class="section-label" id="join">Join Us</h2>
    <div class="join">
      <p class="join-intro">{content.join.intro}</p>
      <div class="join-points">
        {content.join.points.map((point) => (
          <div class="join-point">
            <h3>{point.title}</h3>
            <p>{point.body}</p>
          </div>
        ))}
      </div>
      <p class="join-contact">
        <a href={content.join.contact.href}>{content.join.contact.label} →</a>
      </p>
    </div>
  </div>
</Base>

<style>
  .home { max-width: 44rem; }

  .thesis {
    text-align: center; font-size: clamp(1.6rem, 4.4vw, 2.3rem); line-height: 1.3;
    font-weight: 400; margin: 60px auto 0; max-width: 18em; text-wrap: balance;
  }
  .thesis em { color: var(--accent); font-style: italic; }

  .mission-desc {
    max-width: 38em; margin: 28px auto 0; text-align: center;
    font-size: 1.08rem; color: var(--ink-soft);
  }

  .question { margin: 44px 0; }
  .q-eyebrow { font-family: var(--sans); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft); margin: 0 0 6px; }
  .question h3 { font-size: 1.55rem; font-style: italic; font-weight: 400; line-height: 1.3; margin: 0 0 12px; text-wrap: balance; }
  .question p { font-size: 1rem; color: var(--ink-soft); margin: 0 0 8px; }
  .question .refs { font-family: var(--sans); font-size: 0.78rem; color: var(--ink-soft); }

  /* ---- Projects ---- */
  .projects { display: grid; gap: 20px; margin-top: 32px; }
  .project-card {
    display: flex; gap: 20px; align-items: flex-start; padding: 22px;
    background: var(--panel); border-radius: 4px; color: var(--ink);
  }
  .project-card:hover { text-decoration: none; }
  .project-card:hover h3 { color: var(--accent); }
  .project-logo { width: 56px; height: 56px; object-fit: contain; flex-shrink: 0; border-radius: 4px; }
  .project-body h3 { margin: 0 0 2px; font-size: 1.25rem; font-weight: 600; transition: color 0.12s ease; }
  .project-subtitle { margin: 0 0 8px; font-family: var(--sans); font-size: 0.8rem; letter-spacing: 0.03em; color: var(--ink-soft); }
  .project-desc { margin: 0 0 8px; font-size: 0.98rem; color: var(--ink-soft); }
  .project-funder { margin: 0; font-family: var(--sans); font-size: 0.74rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); }

  /* ---- Team ---- */
  .team-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 28px 18px; margin-top: 32px; text-align: center;
  }
  .team-member img {
    width: 96px; height: 96px; border-radius: 50%; object-fit: cover;
    margin: 0 auto 12px; display: block;
  }
  .team-name { margin: 0; font-size: 0.98rem; font-weight: 600; }
  .team-role { margin: 2px 0 8px; font-family: var(--sans); font-size: 0.72rem; color: var(--ink-soft); }
  .team-projects { margin: 0; display: flex; justify-content: center; gap: 4px; flex-wrap: wrap; }

  .collaborators { margin-top: 44px; text-align: center; }
  .collab-label { font-family: var(--sans); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft); margin: 0 0 8px; }
  .collab-list { margin: 0; font-size: 0.95rem; color: var(--ink-soft); max-width: 42em; margin: 0 auto; }

  /* ---- Publications ---- */
  .pub-intro { max-width: 36em; margin: 24px auto 0; text-align: center; font-size: 0.98rem; color: var(--ink-soft); }
  .pub-list { list-style: none; margin: 24px 0 0; padding: 0; }
  .pub { padding: 16px 0; border-bottom: 1px solid var(--rule); }
  .pub-list .pub:last-child { border-bottom: none; }
  .pub-title { font-size: 1.08rem; font-weight: 600; line-height: 1.3; margin: 0 0 6px; text-wrap: balance; }
  .pub-title a { color: var(--ink); text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 0.5px; text-decoration-color: var(--rule); }
  .pub-title a:hover { color: var(--accent); text-decoration-color: var(--accent); }
  .pub-authors { margin: 0 0 6px; font-size: 0.94rem; color: var(--ink-soft); }
  .pub-venue { margin: 0; display: flex; flex-wrap: wrap; gap: 8px 10px; align-items: baseline; }
  .venue { font-style: italic; }
  .pub-venue .year { font-family: var(--sans); font-size: 0.76rem; color: var(--ink-soft); font-variant-numeric: tabular-nums; }
  .tag { font-family: var(--sans); font-size: 0.64rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-soft); border: 1px solid var(--rule); padding: 1px 7px; border-radius: 3px; }
  a.project-tag { color: var(--accent); border-color: var(--accent); text-decoration: none; transition: border-color 0.12s ease, background-color 0.12s ease; }
  a.project-tag:hover { background: color-mix(in srgb, var(--accent) 8%, transparent); }

  .highlights { margin-top: 32px; padding-bottom: 8px; border-bottom: 1px solid var(--rule); }
  .highlights .pub:first-child { padding-top: 0; }

  .archive-section { border-bottom: 1px solid var(--rule); }
  .archive-section summary {
    cursor: pointer; padding: 16px 0; list-style: none;
    display: flex; align-items: baseline; gap: 12px;
  }
  .archive-section summary::-webkit-details-marker { display: none; }
  .archive-section summary::before {
    content: '+'; font-family: var(--sans); color: var(--ink-soft);
    width: 1em; flex: none;
  }
  .archive-section[open] summary::before { content: '−'; }
  .archive-section summary:hover .summary-title { color: var(--accent); }
  .summary-title { font-family: var(--sans); font-weight: 600; font-size: 0.95rem; font-variant-numeric: tabular-nums; }
  .summary-count { font-family: var(--sans); font-size: 0.76rem; color: var(--ink-soft); }
  .archive-section .pub-list { margin: 0 0 20px; }

  /* ---- Join us ---- */
  .join { margin-top: 32px; }
  .join-intro { font-size: 1.08rem; color: var(--ink-soft); max-width: 38em; margin: 0 auto 32px; text-align: center; }
  .join-points { display: grid; gap: 24px; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
  .join-point h3 { margin: 0 0 6px; font-size: 1.08rem; font-weight: 600; }
  .join-point p { margin: 0; font-size: 0.95rem; color: var(--ink-soft); }
  .join-contact { text-align: center; margin-top: 36px; font-family: var(--sans); font-size: 1rem; }

  @media (max-width: 620px) {
    .thesis { margin-top: 40px; }
    .question { margin: 34px 0; }
    .question h3 { font-size: 1.35rem; }
    .project-card { flex-direction: column; align-items: flex-start; }
    .team-grid { grid-template-columns: repeat(auto-fill, minmax(96px, 1fr)); }
  }
</style>
